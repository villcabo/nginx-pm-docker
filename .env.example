# Image versions
NPM_VERSION=2.14.0
POSTGRES_VERSION=17-alpine

# Ports (host side)
NPM_HTTP_PORT=80
NPM_ADMIN_PORT=81
NPM_HTTPS_PORT=443

# Network MTU (lower to 1450 if running behind VPN/overlay)
NETWORK_MTU=1500

# Uncomment to enable PostgreSQL instead of the default SQLite
#COMPOSE_FILE=docker-compose.yml:docker-compose.postgres.yml

# PostgreSQL credentials (only used when the postgres override is active)
DB_NAME=npm
DB_USER=npm
DB_PASS=npm
